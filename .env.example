# EDM MCP Server Configuration
# Copy this to .env and adjust values

# DeepaData API (required for extract, seal, activate, wiki tools)
DEEPADATA_API_KEY=dda_live_...
DEEPADATA_API_URL=https://deepadata.com

# Anthropic API key (required for wiki article generation)
ANTHROPIC_API_KEY=

# Kimi API (optional - for project tool)
KIMI_API_KEY=

# Storage path for artifacts and envelopes
EDM_STORAGE_PATH=./data

# Authentication (optional - leave empty for no-auth mode)
EDM_AUTH_TOKEN=

# User context for authenticated requests
EDM_USER_ID=local-user
EDM_USER_ROLES=user
EDM_ORG_ID=
